# All defaults work with no .env file. Copy to .env.local to override.

# Force the deterministic mock clinical validator (no API calls, no tokens):
# USE_MOCK_AI=true

# Enable the Claude Agent SDK clinical-evidence layer:
# ANTHROPIC_API_KEY=

# Model for the clinical agent (default: claude-opus-4-8):
# CLAIMIFY_AGENT_MODEL=claude-opus-4-8

# SQLite database location (default: ./claimify-claims.db):
# CLAIMS_DB_PATH=
